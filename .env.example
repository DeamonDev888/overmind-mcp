# ═══════════════════════════════════════════════════════════════════════════════
# OverMind-MCP Environment Configuration (PostgreSQL + pgvector)
# ═══════════════════════════════════════════════════════════════════════════════
# Copiez ce fichier en .env et ajustez les valeurs
# Le postinstall génère un .env avec un password aléatoire automatiquement.
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# POSTGRESQL + PGVECTOR (OverMind Memory Engine)
# ───────────────────────────────────────────────────────────────────────────────

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEME_USE_OVERMIND_SETUP_TO_GENERATE
POSTGRES_DATABASE=overmind_memory
POSTGRES_SSL=false

# Pool de connexions
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# ───────────────────────────────────────────────────────────────────────────────
# OVERMIND CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────
# ATTENTION: Utilisez un chemin ABSOLU, pas ~ (Node.js n'expand pas le tilde)
# Si absent, Overmind utilise ~/.overmind automatiquement.

OVERMIND_WORKSPACE=/home/USER/.overmind
OVERMIND_MEMORY_TYPE=postgres
OVERMIND_LOG_LEVEL=info
OVERMIND_MAX_AGENTS=100

# ───────────────────────────────────────────────────────────────────────────────
# EMBEDDINGS (Qwen 3 Embedding 8B - 4096D)
# ───────────────────────────────────────────────────────────────────────────────

OVERMIND_EMBEDDING_URL=https://openrouter.ai/api/v1
OVERMIND_EMBEDDING_KEY=sk-or-v1-...
OVERMIND_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
OVERMIND_EMBEDDING_DIMENSIONS=4096

# ───────────────────────────────────────────────────────────────────────────────
# API KEYS (pour runners — optionnel)
# ───────────────────────────────────────────────────────────────────────────────

# Anthropic-compatible (MiniMax CN, Z.AI, etc.)
# ANTHROPIC_AUTH_TOKEN=sk-cp-...
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# ANTHROPIC_MODEL=MiniMax-M3
# ANTHROPIC_PROVIDER=minimax-cn

# Suffixes numériques pour rotation de tokens (1-9)
# ANTHROPIC_AUTH_TOKEN_1=
# ANTHROPIC_AUTH_TOKEN_2=

# MiniMax (CN et GLOBAL)
# MINIMAX_CN_API_KEY=
# MINIMAX_API_KEY=

# Z.AI / GLM
# GLM_API_KEY=
# Z_AI_API_KEY=

# Mistral
# MISTRAL_API_KEY=

# OpenAI
# OPENAI_API_KEY=

# NVIDIA NIM
# NVAPI_KEY=

# ElevenLabs (TTS)
# ELEVENLABS_API_KEY=

# ───────────────────────────────────────────────────────────────────────────────
# LOI 25 — CONFORMITÉ PROTECTION DES RP (Québec)
# ───────────────────────────────────────────────────────────────────────────────
# Active la conformité Loi 25. Si false, comportement v3.8 inchangé.
# Docs: docs/PLAN_LOI25_INTEGRATION.md

OVERMIND_LOI25_ENABLED=false

# Rétention active en jours (défaut: 30). Avant ce délai → table active.
OVERMIND_LOI25_RETENTION_DAYS=30

# Archivage cold storage en années (défaut: 5). Après rétention → archive.
OVERMIND_LOI25_ARCHIVE_YEARS=5

# Base légale par défaut: consent | contract | legitimate_interest | legal_obligation
OVERMIND_LOI25_DEFAULT_BASIS=legitimate_interest

# Sujets internes (allowlist) — intérêt légitime suffisant, pas de consentement requis.
# Format: hash1,hash2,hash3 (SHA-256 des identifiants via loi25_consent)
OVERMIND_LOI25_INTERNAL_SUBJECTS=

# Anonymiser automatiquement les RP à l'expiration de la rétention.
OVERMIND_LOI25_AUTO_ANONYMIZE=true

# Salt pour la pseudonymisation (à stocker séparément en production).
# OVERMIND_LOI25_SALT=your-secret-salt-here

# Filtrer les RP des prompts avant envoi aux LLM externes (email, NAS, téléphone, etc.)
OVERMIND_PII_FILTER=false

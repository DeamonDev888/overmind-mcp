# ═══════════════════════════════════════════════════════════════════════════════
# OverMind-MCP Environment Configuration (PostgreSQL + pgvector)
# ═══════════════════════════════════════════════════════════════════════════════
# Configuration pour l'intégration PostgreSQL + pgvector
# Copiez ce fichier en .env et ajustez les valeurs
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# POSTGRESQL + PGVECTOR (OverMind Memory Engine)
# ───────────────────────────────────────────────────────────────────────────────
# Configuration de connexion à PostgreSQL avec pgvector

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=overmind_temp_password_change_me
POSTGRES_DB=overmind_memory
POSTGRES_SSL=false

# Pool de connexions (optimisé pour OverMind)
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# ───────────────────────────────────────────────────────────────────────────────
# OVERMIND CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────
# Configuration principale d'OverMind

OVERMIND_WORKSPACE=~/.overmind
OVERMIND_MEMORY_TYPE=postgres
OVERMIND_LOG_LEVEL=info
OVERMIND_MAX_AGENTS=100

# ───────────────────────────────────────────────────────────────────────────────
# EMBEDDINGS CONFIGURATION (Qwen 3 Embedding 8B - 4096D)
# ───────────────────────────────────────────────────────────────────────────────
# Configuration pour les embeddings vectoriels (4096D)

OVERMIND_EMBEDDING_URL=https://openrouter.ai/api/v1
OVERMIND_EMBEDDING_KEY=sk-or-v1-...
OVERMIND_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
OVERMIND_EMBEDDING_DIMENSIONS=4096

# ───────────────────────────────────────────────────────────────────────────────
# API KEYS (Optionnel - pour différents runners)
# ───────────────────────────────────────────────────────────────────────────────
# Clés API pour les différents services LLM

# OpenAI (pour certains runners)
OPENAI_API_KEY=

# Anthropic (pour Claude runners)
ANTHROPIC_API_KEY=

# Google (pour Gemini runners)
GEMINI_API_KEY=

# ───────────────────────────────────────────────────────────────────────────────
# TELEMETRY & MONITORING (Optionnel)
# ───────────────────────────────────────────────────────────────────────────────
# Activez uniquement si vous utilisez des outils de monitoring

OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=overmind-mcp

# ───────────────────────────────────────────────────────────────────────────────
# DISCORD CONFIGURATION (Optionnel - pour notifications)
# ───────────────────────────────────────────────────────────────────────────────
# Configuration pour les notifications Discord

DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here

# ═══════════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════════════
#
# 1. Copiez ce fichier: cp .env.example .env
# 2. MODIFIEZ OBLIGATOIREMENT:
#    - POSTGRES_PASSWORD (sécurité!)
#    - OVERMIND_EMBEDDING_KEY (pour embeddings)
#    - Vos clés API si nécessaire
# 3. Démarrez PostgreSQL: overmind-postgres up
# 4. Vérifiez la connexion: overmind-postgres status
# 5. Profitez d'OverMind !
#
# ═══════════════════════════════════════════════════════════════════════════════

      "description": "PostgreSQL MCP — vector search + queries (port 5433)"
    },
    "serveur_discord": {
      "transport": "httpStream",
      "url": "http://localhost:3141/mcp",
      "description": "Discord MCP — messages, channels, members (port 3141)"
    }
  },
  "description": "Configuration MCP HTTP Singleton — v3.3. 'overmind' = 14 tools (:3099), 'memory' = 3 tools restreints (:3098 --memory-only). 'discord' est un nom réservé Hermes, utilisez 'serveur_discord'.",
  "version": "3.3.0"
}

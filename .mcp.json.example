{
  "mcpServers": {
    "memory": {
      "transport": "httpStream",
      "url": "http://localhost:3099/mcp",
      "description": "OverMind MCP — orchestration + memory (port 3099)"
    },
    "postgres": {
      "transport": "httpStream",
      "url": "http://localhost:5433/mcp",
      "description": "PostgreSQL MCP — vector search + queries (port 5433)"
    },
    "serveur_discord": {
      "transport": "httpStream",
      "url": "http://localhost:3141/mcp",
      "description": "Discord MCP — messages, channels, members (port 3141)"
    }
  },
  "description": "Configuration MCP HTTP Singleton — v3.1. 'discord' est un nom réservé Hermes, utilisez 'serveur_discord'.",
  "version": "3.1.0"
}

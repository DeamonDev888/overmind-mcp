{
  "mcpServers": {
    "overmind": {
      "transport": "httpStream",
      "url": "http://localhost:3099/mcp",
      "description": "OverMind complet — 14 tools (run_agent, memory_*, create_agent, etc.)"
    },
    "memory": {
      "transport": "httpStream",
      "url": "http://localhost:3099/mcp",
      "description": "Memory-only — 3 tools (memory_search/store/runs, via --memory-only)"
    },
    "postgres": {
      "transport": "httpStream",
      "url": "http://localhost:5433/mcp",
      "description": "PostgreSQL MCP — vector search + queries (port 5433)"
    },
    "serveur_discord": {
      "transport": "httpStream",
      "url": "http://localhost:3141/mcp",
      "description": "Discord MCP — messages, channels, members (port 3141)"
    }
  },
  "description": "'overmind' = 14 tools (:3099), 'memory' = 3 tools restreints (:3099 --memory-only). Même port, accès différent. 'serveur_discord' obligatoire (discord réservé Hermes).",
  "version": "3.3.2"
}

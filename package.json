{
  "name": "claude-code-runner",
  "version": "1.0.0",
  "description": "MCP Server to orchestrate autonomous Claude Code agents — Run, create, and manage AI agents via any MCP-compatible client.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "claude-code-runner": "dist/bin/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/bin/cli.js",
    "bot:news": "node dist/start_bot.js",
    "dev": "tsc -w",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-code",
    "ai-agent",
    "llm",
    "orchestration",
    "automation"
  ],
  "author": "DeaMoN888",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DeaMoN888/claude-code-runner"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.18.0",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "fastmcp": "^3.29.0",
    "pg": "^8.18.0",
    "zod": "^3.24.1"
  }
}

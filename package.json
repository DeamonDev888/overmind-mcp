{
  "name": "overmind-mcp",
  "version": "1.12.0-alpha.1",
  "description": "Orchestrateur universel agents IA multi-modeles via MCP. Inclut le protocole 'Custom-Nickname' pour identifier vos agents avec des surnoms originaux (The Chaos Prophet, Shadow Sniper, etc.), l'isolation mémoire (Private Memory Context) et le support pour QwenCli et Nous Hermes.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "overmind": "dist/bin/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "rebuild": "rimraf dist && tsc",
    "clean": "rimraf dist",
    "start": "node --no-warnings --env-file=.env dist/bin/cli.js",
    "worker:rabbitmq": "node --no-warnings --env-file=.env dist/bin/rabbitmq-worker.js",
    "worker:temporal": "node --no-warnings --env-file=.env dist/bin/temporal-worker.js",
    "dev": "node --no-warnings --watch --env-file=.env dist/bin/cli.js",
    "build:fix": "pnpm run clean && pnpm install && pnpm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm run rebuild"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-code",
    "ai-agent",
    "llm",
    "orchestration",
    "automation"
  ],
  "author": "DeaMoN888",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeamonDev888/overmind-mcp.git"
  },
  "bugs": {
    "url": "https://discord.gg/4AR82phtBz"
  },
  "homepage": "https://deamondev888.github.io/overmind-mcp/",
  "engines": {
    "node": ">=20.0.0 <25"
  },
  "packageManager": "pnpm@10.18.0",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.17",
    "@types/pg": "^8.20.0",
    "@types/pino": "^7.0.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.75.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@temporalio/activity": "^1.17.1",
    "@temporalio/client": "^1.17.1",
    "@temporalio/worker": "^1.17.1",
    "@temporalio/workflow": "^1.17.1",
    "async-mutex": "^0.5.0",
    "dotenv": "^17.4.2",
    "fastmcp": "^3.35.0",
    "overmind-postgres-mcp": "^1.1.6",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^2.2.0",
    "tinyglobby": "^0.2.16",
    "zod": "^4.3.6"
  }
}

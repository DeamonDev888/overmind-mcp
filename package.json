{
  "name": "overmind-mcp",
  "version": "2.8.49",
  "description": "Orchestrateur universel agents IA multi-modeles via MCP. Inclut le protocole 'Custom-Nickname' pour identifier vos agents avec des surnoms originaux (The Chaos Prophet, Shadow Sniper, etc.), l'isolation mémoire (Private Memory Context) et le support pour QwenCli et Nous Hermes. Installation automatique des dépendances Docker (PostgreSQL, pgvector) inclus.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "overmind": "./dist/bin/cli.js",
    "overmind-bridge": "./dist/bin/overmind-bridge.js",
    "overmind-setup": "./scripts/setup.mjs",
    "overmind-postgres-mcp": "./scripts/postgres-manager.mjs",
    "overmind-uninstall": "./scripts/uninstall.mjs",
    "overmind-install-native": "./scripts/install-native.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./bridge": {
      "import": "./dist/bridge/index.js",
      "types": "./dist/bridge/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "docs",
    "scripts",
    "bin",
    ".mcp.json.example"
  ],
  "scripts": {
    "build": "tsc",
    "rebuild": "rimraf dist && tsc",
    "clean": "rimraf dist",
    "start": "node --max-old-space-size=256 --no-warnings --env-file=.env dist/bin/cli.js",
    "dev": "node --max-old-space-size=256 --no-warnings --watch --env-file=.env dist/bin/cli.js",
    "build:fix": "pnpm run clean && pnpm install && pnpm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:install": "node scripts/test-installation.mjs",
    "changeset": "changeset",
    "version": "changeset version && node scripts/auto-changelog.mjs",
    "release": "pnpm run build && changeset publish",
    "prepublishOnly": "pnpm run rebuild",
    "postinstall": "node scripts/postinstall.mjs",
    "setup": "overmind-setup",
    "setup:deps": "node scripts/install-dependencies.mjs",
    "postgres:up": "overmind-postgres-mcp up",
    "postgres:down": "overmind-postgres-mcp down",
    "postgres:status": "overmind-postgres-mcp status",
    "postgres:logs": "overmind-postgres-mcp logs",
    "postgres:reset": "overmind-postgres-mcp reset",
    "prebuild": "node -e \"try{require('fs').copyFileSync('bin/launch.js','dist/bin/launch.js');console.log('Copied launch.js')}catch{console.log('dist/bin not ready yet')}\""
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-code",
    "ai-agent",
    "llm",
    "orchestration",
    "automation",
    "pgvector",
    "docker",
    "auto-installation"
  ],
  "author": "DeaMoN888",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeamonDev888/overmind-mcp.git"
  },
  "bugs": {
    "url": "https://discord.gg/4AR82phtBz"
  },
  "homepage": "https://deamondev888.github.io/overmind-mcp/",
"engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.18.0",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.20.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "dotenv": "^17.4.2",
    "fastmcp": "^4.0.1",
    "overmind-postgres-mcp": "^1.4.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "tinyglobby": "^0.2.16",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "tslib": "^2.0.0"
  }
}
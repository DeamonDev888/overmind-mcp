# ═══════════════════════════════════════════════════════════════════════════════
# OVERMIND MCP — .gitignore
# ═══════════════════════════════════════════════════════════════════════════════
# Règle : tout ce qui contient des secrets, des données personnelles,
# ou qui est regeneré automatiquement par le projet ne doit PAS être commité.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Dependencies ───────────────────────────────────────────────────────────────

node_modules/
.pnp
.pnp.js

# ─── Build output ───────────────────────────────────────────────────────────────

dist/
*.tsbuildinfo

# ─── Environment & Secrets ─────────────────────────────────────────────────────

.env
.env.*                  # includes .env.local, .env.production, .env.test, etc.
!.env.example            # SAUF le template (qui ne contient que des placeholders)
.npmrc
.overmind.env           # legacy

# ─── Agent configs & session data ──────────────────────────────────────────────
# Contains API keys, tokens, absolute paths, session history
# Each agent gets its own .mcp.<name>.json with credentials
__archive__/
.antigravity/
.claude/
.gemini/
.kilo/
.overmind/
.kilocode/
.agent/
browser_data/

# Per-agent config files (contain runner auth tokens)
.mcp.json
mcp.json
.mcp.sniperbot_analyst.json
.mcp.local.json
.mcp.*.json

# ─── Local development ───────────────────────────────────────────────────────────

.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs (can contain sensitive data in raw form)
logs/
*.log

# Local scripts & test files
# (some scripts are tracked — see git ls-files scripts/)
scripts/*
!scripts/auto-changelog.mjs
!scripts/postinstall.mjs
backup/
create_test_agent.js
run_mission.js
verify_memory.js
scratch/
embed-analytics.json
votes_sentinel.csv

# ─── Database & cache ───────────────────────────────────────────────────────────

*.sqlite
*.sqlite-shm
*.sqlite-wal
IndexedDB/
Local Storage/
Cookies/
Cache/
Code Cache/

# ─── Agent sub-projects ────────────────────────────────────────────────────────

agent_multi/node_modules/
agent_multi/dist/
agent_multi/.claude/

# ─── Docker ────────────────────────────────────────────────────────────────────

docker-volumes/
docker-compose.override.yml
docker-compose.*.local.yml

# Docker secrets (never commit)
*.secret
*.password
*.key
*.pem
.secrets/

# Example configs (keep the template, ignore local overrides)
!config/*.example.yml
config/prometheus.yml
config/otel-collector.yml

# ─── Coverage ──────────────────────────────────────────────────────────────────

coverage/

# ─── Misc ─────────────────────────────────────────────────────────────────────

*.txt
notes/
